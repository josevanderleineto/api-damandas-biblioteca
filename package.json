{
  "name": "api-demandas",
  "version": "1.0.0",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "desktop:dev": "electron .",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:all": "node scripts/build-all.js",
    "db:migrate": "node scripts/applySchema.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "private": true,
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^6.10.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "br.com.uniftc.sistemaDemandasBiblioteca",
    "productName": "Sistema de Demandas (Biblioteca)",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist-desktop/**",
      "!**/.DS_Store"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
